# =============================================================================
# MeetingBox appliance (mini-pc) — copy to .env and edit.
# Covers: Docker Compose profiles, device-ui (Kivy), host/Docker audio, Redis.
# =============================================================================

# --- Compose: which containers to run (comma-separated, no spaces) ---
# Without ``docker-audio``, Redis + mic containers are NOT started (Compose profiles).
#
# typical: UI + Docker mic + local Redis for the audio container
COMPOSE_PROFILES=mini-pc,docker-audio
#
# UI only (use host script: audio/run_audio_capture.sh instead of Docker mic)
# COMPOSE_PROFILES=mini-pc
#
# Mic + Redis only (no Kivy container)
# COMPOSE_PROFILES=docker-audio

# --- device-ui X11 (built-in screen) — keep these in .env for a permanent kiosk setup ---
# SSH sets DISPLAY=localhost:10.0; that must NOT be passed into the container.
# Compose uses this variable only (default :0). Set :1 if ``ls /tmp/.X11-unix`` shows only X1.
DEVICE_UI_DISPLAY=:0
#
# Xauthority: the file you mount MUST contain a MIT-MAGIC-COOKIE for THIS display (e.g. :0).
# If you see "no :0 / unix:0 entry" you mounted a cookie from SSH (:10) or an empty file.
# Fix — on the built-in screen (not SSH), open a terminal as the logged-in GUI user and run:
#   echo $DISPLAY          # expect :0
#   xauth list $DISPLAY    # must print one line with MIT-MAGIC-COOKIE
# Then set XAUTHORITY_HOST to THAT user’s file, e.g.:
XAUTHORITY_HOST=/home/meetingbox/.Xauthority
# GDM auto-login often keeps the cookie here instead (replace 1000 with ``id -u`` of the GUI user):
# XAUTHORITY_HOST=/run/user/1000/gdm/Xauthority
# Boot script can copy a good cookie to e.g. ./.meetingbox-docker.xauth and set MEETINGBOX_X11_COOKIE for compose.
# Kiosk: borderless fullscreen (default in docker-compose is 1; set 0 only for desktop debugging).
FULLSCREEN=1
#
# --- UI scaling (required for large / ultrawide panels) ---
# Kivy uses these as the logical window size; home screen scales from 1024×600 relative to this.
# Docker defaults to 1024×600, so widgets stay small on a big panel until you fix this.
# Option A — set to match ``xrandr`` “current” (example: 3520×1080 ultrawide):
#   DISPLAY_WIDTH=3520
#   DISPLAY_HEIGHT=1080
# Option B — auto from host X11 (container runs xrandr; overrides DISPLAY_* defaults):
#   MEETINGBOX_SYNC_DISPLAY_FROM_XRANDR=1

# --- Cloud / remote API (required for mini PC talking to VPS) ---
BACKEND_URL=http://meetingboxai.duckdns.org:8000
BACKEND_WS_URL=ws://meetingboxai.duckdns.org:8000/ws
# Shown in UI / QR (full URL or host:port — see device-ui README)
DASHBOARD_URL=http://meetingboxai.duckdns.org:8000/

# --- Restart / power off from device-ui (Docker) ---
# Compose mounts scripts/meetingbox-host-* and sets privileged: true so nsenter can join the host’s
# PID/mount namespaces (without it: "reassociate to namespaces failed: Operation not permitted").
# Rebuild the UI image after git pull (needs util-linux in the image). Flow: local helper first,
# then PATCH /api/device/settings if local fails. Rootless Docker may still block — run UI on the host
# or set MEETINGBOX_LOCAL_REBOOT_CMD to a host script.

# Optional: same as web APP_BASE_URL if you merge env files; run_device_ui maps it to BACKEND_URL
# APP_BASE_URL=http://meetingboxai.duckdns.org:8000

# --- Mic command transport (Docker ``audio`` service + host capture script) ---
# If DEVICE_AUTH_TOKEN is set, leave AUDIO_COMMAND_SOURCE unset → HTTP long-poll to the cloud API.
# Local Compose Redis does not receive commands published by the remote API.
#   http — force long-poll ``GET /api/device/audio-command/wait``
#   redis — only when this process uses the same Redis as the API (or an SSH tunnel to it)
# AUDIO_COMMAND_SOURCE=
# Optional override for long-poll base URL (else derived from UPLOAD_AUDIO_API_URL)
# AUDIO_POLL_BASE_URL=https://meetingboxai.duckdns.org

# Redis for ``redis`` command mode + publishing mic level events (optional in http mode if unreachable)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
UPLOAD_AUDIO_ON_STOP=1
UPLOAD_AUDIO_API_URL=http://meetingboxai.duckdns.org:8000/api/meetings/upload-audio
UPLOAD_AUDIO_TIMEOUT_SECONDS=1200
# After device pairing — same token as in device-ui / upload headers
# DEVICE_AUTH_TOKEN=mbd_...

# Mic selection (optional) — used by Docker ``audio`` and ``device-ui`` (mic test waveform)
# AUDIO_INPUT_DEVICE_INDEX=1
# AUDIO_INPUT_DEVICE_NAME=USB

# --- Docker audio service (when COMPOSE_PROFILES includes docker-audio) ---
# Same vars are passed through compose; override here if needed.

# --- Start Docker stack on boot (systemd) ---
# On the mini PC (from this repo directory, or pass the install path as the first argument):
#   sudo bash scripts/install-boot-service.sh
#   sudo systemctl start meetingbox-appliance
# Prereqs: Docker + Compose v2; GUI user in group ``docker`` (``sudo usermod -aG docker meetingbox``);
# enable **automatic login** to the graphical session on the built-in screen so :0 and .Xauthority exist.
# The unit runs ``xhost +local:docker`` before ``docker compose up -d`` (same as a permanent X fix).
#
# If the UI starts before X is ready, add a short delay:
#   sudo systemctl edit meetingbox-appliance
#   # [Service] \n ExecStartPre=/bin/sleep 15
#
# --- Kivy / kiosk (built-in panel) ---
# The UI must attach to the **local** X session on the mini PC (not SSH X11).
#
# 1) Log in on the device’s own screen so a desktop/X session is running.
# 2) Keep DEVICE_UI_DISPLAY, XAUTHORITY_HOST, FULLSCREEN in this .env (see top of file).
# 3) Wayland-only sessions often have no X socket until XWayland starts. If /tmp/.X11-unix is empty,
#    choose “Ubuntu on Xorg” at the login gear, or disable Wayland in GDM, then reboot.
# 4) GDM cookie path (if ~/.Xauthority is wrong): XAUTHORITY_HOST=/run/user/1000/gdm/Xauthority
# 5) Touch: add prod override so the container can read evdev:
#      docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# DEVICE_UI_DISPLAY=:1
# MOCK_BACKEND=0
#
# X11 from Docker: if logs show "Authorization required, but no authorization protocol specified",
# the UI container needs the same user's cookie file as the desktop session.
# Default mount is ${HOME}/.Xauthority — run `docker compose` as that user (not sudo), after a local GUI login.
# GDM sometimes uses /run/user/$(id -u)/gdm/Xauthority — then set e.g.:
# XAUTHORITY_HOST=/run/user/1000/gdm/Xauthority
# Optional fallback: on the host (while logged into :0) run: xhost +local:docker
#
# EGL /dev/dri/renderD128 "Permission denied": check group on the node:
#   ls -l /dev/dri/renderD128
# If the group column is ``video``, the default compose ``group_add`` is enough.
# If it is ``render`` but your OS has no ``render`` group yet:
#   sudo groupadd render && sudo chgrp render /dev/dri/renderD128   # or reboot after udev rules
# Then add docker-compose.override.yml next to compose with:
#   services:
#     device-ui:
#       group_add:
#         - render
