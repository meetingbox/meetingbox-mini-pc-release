# MeetingBox native device UI runtime config.
# Installed to /etc/meetingbox/device-ui.env by the .deb package.

# Local display created by xinit/openbox or another minimal X11 session.
DEVICE_UI_DISPLAY=:0

# Kiosk defaults. Set FULLSCREEN=0 only for desktop debugging.
FULLSCREEN=1
SHOW_MOUSE_CURSOR=0

# Match your physical display. You can also set MEETINGBOX_SYNC_DISPLAY_FROM_XRANDR=1.
DISPLAY_WIDTH=1024
DISPLAY_HEIGHT=600
# MEETINGBOX_SYNC_DISPLAY_FROM_XRANDR=1

# Backend / dashboard.
# Must match the cloud dashboard where Gmail/Calendar integrations are connected.
BACKEND_URL=https://meetingboxai.lucratechsol.com
BACKEND_WS_URL=wss://meetingboxai.lucratechsol.com/ws
DASHBOARD_URL=https://meetingboxai.lucratechsol.com/
MOCK_BACKEND=0

# Local audio / Redis integration, if used.
LOCAL_REDIS_HOST=127.0.0.1
LOCAL_REDIS_PORT=6379
AUDIO_INPUT_DEVICE_INDEX=
AUDIO_INPUT_DEVICE_NAME=

# Optional device auth token. Prefer pairing flow so this lands in /opt/meetingbox/data/config.
# DEVICE_AUTH_TOKEN=mbd_...
