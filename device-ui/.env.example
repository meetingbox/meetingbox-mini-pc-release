# Copy to .env and set your cloud nginx URL (same host you use in the browser).
# run_device_ui.sh loads this after repo-root .env.
#
# BACKEND_URL=https://meetingboxai.lucratechsol.com
# BACKEND_WS_URL=wss://meetingboxai.lucratechsol.com/ws
# If server uses MEETINGBOX_WS_SHARED_SECRET, set the same on device:
# BACKEND_WS_SHARED_SECRET=
# MEETINGBOX_WS_SHARED_SECRET=
# If server uses MEETINGBOX_WS_REQUIRE_AUTH=1, pairing token is sent as ?access_token= on /ws automatically.
# DASHBOARD_URL=https://meetingboxai.lucratechsol.com/
#
# Seconds you have after wake to speak a command (minimum 5 enforced):
# VOICE_ASSISTANT_COMMAND_TIMEOUT=20
#
# After assistant speech: shorter = snappier mic, longer = less echo false-wake (seconds):
# MEETINGBOX_TTS_TAIL_SILENCE_SEC=1.15
# MEETINGBOX_POST_TTS_WAKE_GUARD_SEC=0.6
#
# Optional ALSA output device for assistant TTS (aplay -D …), e.g. plughw:0,0 or pulse:
# MEETINGBOX_APLAY_DEVICE=
