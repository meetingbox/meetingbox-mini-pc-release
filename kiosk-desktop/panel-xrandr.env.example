# Copy to /etc/meetingbox/panel-xrandr.env (install-gdm-kiosk-session.sh does this once).
# Applied at the start of meetingbox-gdm-kiosk-session via apply-kiosk-display-orientation.sh.
# Run `xrandr` on the device to see output names (e.g. DSI-1, HDMI-1).

MEETINGBOX_PANEL_OUTPUT=DSI-1
MEETINGBOX_PANEL_MODE=800x1280
MEETINGBOX_PANEL_ROTATE=right

# Set to 1 to skip applying xrandr (e.g. desktop monitor debugging):
# MEETINGBOX_SKIP_PANEL_XRANDR=1
