#!/bin/bash
# startx entry: no GDM — black screen, Openbox, Docker MeetingBox UI.
# Installed to ~/.xinitrc-meetingbox by install-xinit-no-gdm.sh

export PATH="/usr/sbin:/usr/bin:/usr/local/bin:$PATH"

RELEASE="$(tr -d '\n' </etc/meetingbox/release 2>/dev/null || echo "$HOME/meetingbox-mini-pc-release")"
RELEASE=$(cd "$RELEASE" && pwd)

if [[ -x /usr/local/bin/meetingbox-apply-kiosk-display-orientation ]]; then
  /usr/local/bin/meetingbox-apply-kiosk-display-orientation
elif [[ -f "$RELEASE/scripts/apply-kiosk-display-orientation.sh" ]]; then
  bash "$RELEASE/scripts/apply-kiosk-display-orientation.sh"
fi

xsetroot -solid '#000000' 2>/dev/null || true
command -v openbox >/dev/null 2>&1 && openbox >/dev/null 2>&1 &
sleep 0.25

echo "xinit-meetingbox: waiting for Docker (max ~15s)..."
for _ in $(seq 1 60); do
  docker info >/dev/null 2>&1 && break
  sleep 0.25
done

if [[ -f "$RELEASE/scripts/kiosk-compose-up.sh" ]]; then
  (
    bash "$RELEASE/scripts/kiosk-compose-up.sh" "$RELEASE" 2>&1 | logger -t meetingbox-xinit-compose
  ) &
  disown "$!" 2>/dev/null || true
else
  logger -t meetingbox-xinit "missing $RELEASE/scripts/kiosk-compose-up.sh"
fi

exec tail -f /dev/null
