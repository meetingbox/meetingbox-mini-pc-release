# =============================================================================
# MeetingBox for Windows - configuration
# Loaded at startup. Lines are KEY=VALUE. '#' starts a comment.
# Real environment variables override anything set here.
# Installed to:  %PROGRAMDATA%\MeetingBox\device-ui.env  (edit then relaunch)
# =============================================================================

# --- Backend (cloud) -----------------------------------------------------
BACKEND_URL=https://meetingboxai.lucratechsol.com
BACKEND_WS_URL=wss://meetingboxai.lucratechsol.com/ws
DASHBOARD_URL=https://meetingboxai.lucratechsol.com/

# --- Audio upload --------------------------------------------------------
UPLOAD_AUDIO_ON_STOP=1
UPLOAD_AUDIO_API_URL=https://meetingboxai.lucratechsol.com/api/meetings/upload-audio
UPLOAD_AUDIO_TIMEOUT_SECONDS=7200

# --- Window (retain the 7-inch device layout) ----------------------------
DISPLAY_WIDTH=1024
DISPLAY_HEIGHT=600
# Desktop app runs windowed (not kiosk) and shows the mouse cursor for clicks.
FULLSCREEN=0
SHOW_MOUSE_CURSOR=1

# --- Audio capture (Windows uses PortAudio via sounddevice) --------------
AUDIO_CAPTURE_BACKEND=sounddevice
AUDIO_OUTPUT_DEVICE=default
# Spawn the bundled meetingbox-audio.exe capture child (meeting recording).
MEETINGBOX_SPAWN_AUDIO=1

# --- Voice assistant (OpenAI Realtime) -----------------------------------
# The wake word ("Hey Pepper") is detected locally on-device (Vosk +
# PortAudio). On wake, the app requests an ephemeral OpenAI Realtime client
# secret from the backend (POST /api/voice/realtime/session) and connects
# directly to wss://api.openai.com/v1/realtime. No API key lives on the PC,
# and there is NO LiveKit/Pipecat involvement on the device.
#
# Realtime is ON by default; no flag required. Optional overrides:
#   MEETINGBOX_WAKE_LOCAL_VOICE_ONLY=1  -> never start Realtime (local Vosk only)
#   REALTIME_WARM_STANDBY=0             -> disable the pre-warmed session
# (Realtime must also be enabled server-side: backend OPENAI_API_KEY +
#  MEETINGBOX_REALTIME_VOICE_ENABLED. Those are server config, not set here.)
#
# --- Echo cancellation (open-speaker full-duplex barge-in) ---------------
# On a laptop with built-in speakers + mic, the device hears its own voice.
# To let you talk over the assistant ("barge-in") without it interrupting
# itself, MeetingBox uses the WINDOWS VOICE CAPTURE DSP — the OS-level echo
# canceller (same class of tech phone assistants use). It captures the mic and
# references the speaker output itself, so the assistant's voice is removed at
# the source and the live mic is genuinely clean. This is ON by default and
# supersedes the older Speex + WASAPI-loopback path whenever it starts.
#
#   REALTIME_OS_AEC=1   # 1=use Windows Voice Capture DSP (default, recommended).
#                       # 0=fall back to the in-app Speex canceller (half-duplex).
# Notes:
#   * Uses the Windows DEFAULT communications mic + speaker. Pick those in
#     Windows Sound settings (the app no longer needs AUDIO_INPUT_DEVICE_NAME).
#   * Headphones still work and remove echo physically; the OS AEC is for the
#     open-speaker case. A USB conference puck also works.

# --- Turn-taking / how it decides you've finished ------------------------
# With the clean OS-AEC mic, the desktop defaults to energy-based "server_vad":
# it focuses on the active talker, ignores sound below the threshold, and
# commits a fixed time after you stop — so it won't sit waiting on ambient room
# noise, and it stops the assistant the instant you barge in.
#
#   REALTIME_TURN_DETECTION=server_vad  # server_vad | semantic_vad | auto
#   REALTIME_VAD_THRESHOLD=0.6          # 0..1. Higher = ignore quieter sounds
#                                       # (raise if ambient noise keeps it
#                                       # listening; lower if it misses soft speech).
#   REALTIME_VAD_SILENCE_MS=500         # silence after you stop before it replies
#                                       # (lower = snappier, higher = fewer cut-offs).
#   REALTIME_VAD_PREFIX_MS=300          # audio kept before speech so the first
#                                       # word isn't clipped.

# --- Wake word sensitivity -----------------------------------------------
# "Hey Pepper" is matched structurally (a "hey" sound followed by a
# "pepper" sound), so accents / mis-hearings like "hey peppa", "hey paper",
# "hey pepe" still wake on the first try — without waking on the plain word
# "pepper" mid-conversation.
#   VOICE_ASSISTANT_WAKE_THRESHOLD=0.82 # fuzzy bar for the "pepper" token.
#                                       # Lower (e.g. 0.78) = even easier to wake;
#                                       # raise toward 0.9 if it wakes too easily.

# --- Desktop mic / voice-quality tuning ----------------------------------
# A PC's built-in mic + speakers are acoustically coupled and quieter/noisier
# than the appliance's far-field USB array. These knobs tune the live voice
# path for that. Defaults are sane; uncomment only to fine-tune. After AEC
# (libspeexdsp) + anti-aliased capture, most setups need no changes.
#
#   REALTIME_INPUT_GAIN=1.0       # digital mic gain (1.0=off). Try 1.5-2.5 if
#                                 # the assistant often "doesn't hear" you.
#   REALTIME_BARGE_IN_MIN_RMS=500 # lower = easier to interrupt (desktop default
#                                 # 500). Raise if your own voice/echo self-trips.
#   REALTIME_SPEECH_UPLINK_S=3.0  # how long the mic uplink stays open after the
#                                 # server detects you talking (captures full turn).
#   REALTIME_MIC_TAIL_S=0.5       # echo-mute tail after the assistant stops.
#   REALTIME_VAD_EAGERNESS=medium # low|medium|high|auto (reply speed after you stop).
#   REALTIME_HALF_DUPLEX=auto     # auto|1|0. auto=half-duplex unless a combined
#                                 # echo-isolated mic+speaker puck is detected.
#   AUDIO_INPUT_DEVICE_NAME=      # substring to force a specific mic (e.g. a USB
#                                 # headset) instead of the Windows default.
# Best real-world quality: use a USB headset or conference mic (removes echo
# coupling entirely; the app then runs full-duplex automatically).

# --- Device pairing ------------------------------------------------------
# Leave unset for a fresh install: the app shows the pairing screen and
# writes its own token under %LOCALAPPDATA%\MeetingBox\data\config.
# DEVICE_AUTH_TOKEN=

# --- Logging safety (this dist_mock exe is a stale build) ----------------
# The bundled MeetingBox.exe predates the source fix that sets
# KIVY_NO_CONSOLELOG. Without these, a log line containing a non-ASCII glyph
# (e.g. the "Nav ->" arrow) fails to encode on the cp1252 console stream; the
# error is written to Kivy's stderr wrapper, recaptured into logging, and
# recurses forever -- ballooning RAM to several GB. Disabling the console log
# handler and Kivy's stderr hijack stops the runaway. Remove after rebuilding.
LOG_TO_CONSOLE=0
KIVY_NO_CONSOLELOG=1
# Raise the log level so INFO lines like "Nav -> <screen>" (which contain the
# U+2192 arrow) are never emitted, so they can't hit the cp1252 handler that
# triggers the recursion in this stale exe. Lower to INFO after rebuilding.
LOG_LEVEL=ERROR
