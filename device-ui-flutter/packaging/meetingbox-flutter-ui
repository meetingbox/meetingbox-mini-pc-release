#!/usr/bin/env bash
# Launcher for the native Flutter MeetingBox device UI (kiosk).
# Installed to /usr/bin/meetingbox-flutter-ui by the .deb package.

set -euo pipefail

ENV_FILE=/etc/meetingbox/device-ui-flutter.env
if [[ -f "$ENV_FILE" ]]; then
  # shellcheck source=/dev/null
  set -a; source "$ENV_FILE"; set +a
fi

export DISPLAY="${DEVICE_UI_DISPLAY:-${DISPLAY:-:0}}"

BUNDLE_DIR=/usr/lib/meetingbox/device-ui-flutter
BIN="$BUNDLE_DIR/meetingbox_device_ui"

if [[ ! -x "$BIN" ]]; then
  echo "MeetingBox Flutter UI binary not found at $BIN" >&2
  exit 1
fi

# The Flutter engine needs to find its bundled lib/ and data/ relative to CWD.
cd "$BUNDLE_DIR"
exec "$BIN" "$@"
