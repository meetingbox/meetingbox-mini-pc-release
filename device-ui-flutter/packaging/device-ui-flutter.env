# MeetingBox Flutter device UI runtime/build config.
# Installed to /etc/meetingbox/device-ui-flutter.env by the .deb package.
#
# BACKEND_URL and related keys are read at runtime from this file (launcher /
# systemd) and also baked into release builds via --dart-define when using
# build-device-ui-flutter-deb.sh.

# Local display created by the graphical session (X11 :0 or Wayland).
DEVICE_UI_DISPLAY=:0

# Kiosk defaults. Set FULLSCREEN=0 only for desktop debugging.
FULLSCREEN=1

# Physical panel size used by the Figma 1260x800 canvas scaler.
DISPLAY_WIDTH=1260
DISPLAY_HEIGHT=800

# Backend / dashboard — must match the cloud dashboard where Gmail/Calendar
# integrations are connected.
BACKEND_URL=https://meetingboxai.lucratechsol.com
BACKEND_WS_URL=wss://meetingboxai.lucratechsol.com/ws
DASHBOARD_PUBLIC_URL=https://meetingboxai.lucratechsol.com/
MOCK_BACKEND=0

# Local data root on the appliance (device auth token + audio paths).
MEETINGBOX_DATA_ROOT=/home/meetingbox/meetingbox-mini-pc-release

# Local Python device bridge (device-services). Keep on loopback.
DEVICE_BRIDGE_URL=http://127.0.0.1:8765
DEVICE_BRIDGE_HOST=127.0.0.1
DEVICE_BRIDGE_PORT=8765

# Optional device auth token (prefer the on-device pairing flow instead).
# DEVICE_AUTH_TOKEN=mbd_...
