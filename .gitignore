.env
# Refreshed at boot by scripts/kiosk-compose-up.sh for Docker X11 bind mount
.meetingbox-docker.xauth
.venv/
dist/
device-ui/.build-native-venv/
device-ui/.venv/
audio/.venv/
__pycache__/
*.pyc
data/audio/recordings/*
!data/audio/recordings/.gitkeep
data/audio/temp/*
!data/audio/temp/.gitkeep
data/config/*
!data/config/.gitkeep

# Windows packaging build artifacts (regenerated by PyInstaller / Inno Setup)
packaging/windows/build/
packaging/windows/dist/
packaging/windows/Output/
packaging/windows/*.log
packaging/windows/meetingbox_icon_src.png

# Downloaded Vosk wake-word model + local UI state (created at runtime)
device-ui/data/

# Ad-hoc debug captures
_screenshot_*.png
_winrun*.log
