#!/bin/sh
# Run nmcli on the HOST via nsenter so NetworkManager polkit checks pass.
#
# Inside Docker, nmcli is not recognized as authorized by the host's polkit
# even with pid:host and privileged:true. Running via nsenter as root (uid 0)
# in the host's namespaces bypasses polkit entirely — root always has full
# NetworkManager access.
#
# Requires: docker-compose ``pid: host``, ``privileged: true``,
#           rebuilt image with sudo+sudoers entry for this path.
# Called by wifi_nmcli_local.py when a plain nmcli call returns
# "Not authorized to control networking".

SELF=/usr/local/bin/meetingbox-wifi-nmcli

if [ "$(id -u)" -ne 0 ]; then
  if ! command -v sudo >/dev/null 2>&1; then
    echo "meetingbox-wifi-nmcli: need root but sudo is missing" >&2
    exit 1
  fi
  sudo -n "$SELF" "$@" || {
    echo "meetingbox-wifi-nmcli: sudo -n failed (check sudoers NOPASSWD for $SELF)" >&2
    exit 1
  }
  exit 0
fi

if ! command -v nsenter >/dev/null 2>&1; then
  echo "meetingbox-wifi-nmcli: nsenter not found (install util-linux)" >&2
  exit 1
fi

exec nsenter -t 1 -m -u -i -n -p -- nmcli "$@"
