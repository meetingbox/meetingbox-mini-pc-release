# =============================================================================
# MeetingBox for Windows - configuration
# Loaded at startup. Lines are KEY=VALUE. '#' starts a comment.
# Real environment variables override anything set here.
# Installed to:  %PROGRAMDATA%\MeetingBox\device-ui.env  (edit then relaunch)
# =============================================================================

# --- Backend (cloud) -----------------------------------------------------
BACKEND_URL=https://meetingboxai.lucratechsol.com
BACKEND_WS_URL=wss://meetingboxai.lucratechsol.com/ws
DASHBOARD_URL=https://meetingboxai.lucratechsol.com/

# --- Audio upload --------------------------------------------------------
UPLOAD_AUDIO_ON_STOP=1
UPLOAD_AUDIO_API_URL=https://meetingboxai.lucratechsol.com/api/meetings/upload-audio
UPLOAD_AUDIO_TIMEOUT_SECONDS=7200

# --- Window (retain the 7-inch device layout) ----------------------------
DISPLAY_WIDTH=1024
DISPLAY_HEIGHT=600
# Desktop app runs windowed (not kiosk) and shows the mouse cursor for clicks.
FULLSCREEN=0
SHOW_MOUSE_CURSOR=1

# --- Audio capture (Windows uses PortAudio via sounddevice) --------------
AUDIO_CAPTURE_BACKEND=sounddevice
AUDIO_OUTPUT_DEVICE=default
# Spawn the bundled meetingbox-audio.exe capture child (meeting recording).
MEETINGBOX_SPAWN_AUDIO=1

# --- Voice assistant (OpenAI Realtime) -----------------------------------
# The wake word ("Hey Pepper") is detected locally on-device (Vosk +
# PortAudio). On wake, the app requests an ephemeral OpenAI Realtime client
# secret from the backend (POST /api/voice/realtime/session) and connects
# directly to wss://api.openai.com/v1/realtime. No API key lives on the PC,
# and there is NO LiveKit/Pipecat involvement on the device.
#
# Realtime is ON by default; no flag required. Optional overrides:
#   MEETINGBOX_WAKE_LOCAL_VOICE_ONLY=1  -> never start Realtime (local Vosk only)
#   REALTIME_WARM_STANDBY=0             -> disable the pre-warmed session
# (Realtime must also be enabled server-side: backend OPENAI_API_KEY +
#  MEETINGBOX_REALTIME_VOICE_ENABLED. Those are server config, not set here.)

# --- Device pairing ------------------------------------------------------
# Leave unset for a fresh install: the app shows the pairing screen and
# writes its own token under %LOCALAPPDATA%\MeetingBox\data\config.
# DEVICE_AUTH_TOKEN=
